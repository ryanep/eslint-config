{
  "name": "@ryanep/eslint-config",
  "forwardPorts": ["1455:1455"],
  "postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder}",
  "postCreateCommand": "npm install",
  "remoteUser": "node",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1.6.3": { "version": "22.14.0" },
    "ghcr.io/devcontainers/features/github-cli:1.1.0": { "version": "2.87.3" },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1.6.3": {},
    "ghcr.io/devcontainers-extra/features/opencode:1.0.0": {
      "version": "1.1.39"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "waderyan.gitblame"
      ]
    }
  }
}
